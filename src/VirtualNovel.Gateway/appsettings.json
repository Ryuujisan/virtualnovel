{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "users-get-route": {
        "ClusterId": "users-cluster",
        "Order": 0,
        "Match": {
          "Path": "/api/users/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "users-protected-route": {
        "ClusterId": "users-cluster",
        "Order": 1,
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "novels-get-route": {
        "ClusterId": "novels-cluster",
        "Order": 0,
        "Match": {
          "Path": "/api/novels/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "novels-protected-route": {
        "ClusterId": "novels-cluster",
        "Order": 1,
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/novels/{**catch-all}"
        }
      },
      "chapters-get-route": {
        "ClusterId": "novels-cluster",
        "Order": 0,
        "Match": {
          "Path": "/api/chapters/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "chapters-protected-route": {
        "ClusterId": "novels-cluster",
        "Order": 1,
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/chapters/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5033/"
          }
        }
      },

      "novels-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5289/"
          }
        }
      }
    }
  }
}
